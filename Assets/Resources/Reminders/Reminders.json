{
  "language": "tr",
  "version": 1,
  "items": [
    { "id": 1, "text": "İyilik yapmak sadakadır.", "source": "Öğüt" },
    { "id": 2, "text": "Sabır, zorluğun anahtarıdır.", "source": "Öğüt" },
    { "id": 3, "text": "Güzel söz, gönülleri yumuşatır.", "source": "Öğüt" },
    { "id": 4, "text": "Allah’ı anmak kalpleri huzura kavuşturur.", "source": "Öğüt" },
    { "id": 5, "text": "Komşuya iyilik imanın güzelliğindendir.", "source": "Öğüt" },
    { "id": 6, "text": "İnsanların en hayırlısı insanlara faydalı olandır.", "source": "Öğüt" },
    { "id": 7, "text": "Affetmek, kalbi güçlendirir.", "source": "Öğüt" },
    { "id": 8, "text": "Kibir, insanı küçültür.", "source": "Öğüt" },
    { "id": 9, "text": "Şükür, nimeti artırır.", "source": "Öğüt" },
    { "id": 10, "text": "Doğruluk insanı güvenilir yapar.", "source": "Öğüt" },

    { "id": 11, "text": "Güzel ahlak en büyük zenginliktir.", "source": "Öğüt" },
    { "id": 12, "text": "Kalp kırmak kolaydır, onarmak zordur.", "source": "Öğüt" },
    { "id": 13, "text": "Merhamet eden merhamet bulur.", "source": "Öğüt" },
    { "id": 14, "text": "İyilik, insanın ruhunu temizler.", "source": "Öğüt" },
    { "id": 15, "text": "Hakkı söylemek cesaret ister.", "source": "Öğüt" },
    { "id": 16, "text": "Zulüm karanlıktır.", "source": "Öğüt" },
    { "id": 17, "text": "Gıybet kalbi karartır.", "source": "Öğüt" },
    { "id": 18, "text": "Helal kazanç bereket getirir.", "source": "Öğüt" },
    { "id": 19, "text": "Dua, müminin silahıdır.", "source": "Öğüt" },
    { "id": 20, "text": "Allah’ın rahmeti geniştir.", "source": "Öğüt" },

    { "id": 21, "text": "Az konuşmak hikmettir.", "source": "Öğüt" },
    { "id": 22, "text": "Kalp temizliği ibadetin özüdür.", "source": "Öğüt" },
    { "id": 23, "text": "Zenginlik malda değil, gönüldedir.", "source": "Öğüt" },
    { "id": 24, "text": "Kırıcı değil, yapıcı ol.", "source": "Öğüt" },
    { "id": 25, "text": "Güzel davranış, insanın süsüdür.", "source": "Öğüt" },
    { "id": 26, "text": "Kardeşine yardım eden yalnız kalmaz.", "source": "Öğüt" },
    { "id": 27, "text": "Niyet temiz olursa amel değer kazanır.", "source": "Öğüt" },
    { "id": 28, "text": "Öfke, şeytanın ateşidir.", "source": "Öğüt" },
    { "id": 29, "text": "Öfkeyi yutmak büyük erdemdir.", "source": "Öğüt" },
    { "id": 30, "text": "Güzel niyet, hayrı büyütür.", "source": "Öğüt" },

    { "id": 31, "text": "Dürüstlük, insanın şerefidir.", "source": "Öğüt" },
    { "id": 32, "text": "Sözünde durmak müminin alametidir.", "source": "Öğüt" },
    { "id": 33, "text": "Kimseyi küçük görme.", "source": "Öğüt" },
    { "id": 34, "text": "Mütevazı olan yükselir.", "source": "Öğüt" },
    { "id": 35, "text": "Kul hakkı ağır bir yüktür.", "source": "Öğüt" },
    { "id": 36, "text": "Kırdığın gönül, yaptığın ibadeti eksiltir.", "source": "Öğüt" },
    { "id": 37, "text": "İman sabırla güçlenir.", "source": "Öğüt" },
    { "id": 38, "text": "Dünyaya aldanma, ahireti unutma.", "source": "Öğüt" },
    { "id": 39, "text": "Kötülüğe iyilikle karşılık ver.", "source": "Öğüt" },
    { "id": 40, "text": "İnsanların kusurunu arama, kendi kusuruna bak.", "source": "Öğüt" },

    { "id": 41, "text": "Kıskançlık kalbi yorar.", "source": "Öğüt" },
    { "id": 42, "text": "Kendin için istediğini başkası için de iste.", "source": "Öğüt" },
    { "id": 43, "text": "Güzel ahlak, en büyük ibadetlerden biridir.", "source": "Öğüt" },
    { "id": 44, "text": "İnsanları sevmek imanın işaretidir.", "source": "Öğüt" },
    { "id": 45, "text": "Kötü söz sadaka değildir, susmak daha hayırlıdır.", "source": "Öğüt" },
    { "id": 46, "text": "Anne-baba duası büyük nimettir.", "source": "Öğüt" },
    { "id": 47, "text": "Yetim sevindirmek büyük sevaptır.", "source": "Öğüt" },
    { "id": 48, "text": "Zor durumda olanı gözetmek rahmettir.", "source": "Öğüt" },
    { "id": 49, "text": "Allah için yapılan iyilik boşa gitmez.", "source": "Öğüt" },
    { "id": 50, "text": "Her zorlukla beraber bir kolaylık vardır.", "source": "Öğüt" },

    { "id": 51, "text": "Kalp kırmak, taş kırmaktan ağırdır.", "source": "Öğüt" },
    { "id": 52, "text": "İnsanı değerli yapan takvasıdır.", "source": "Öğüt" },
    { "id": 53, "text": "Az ama sürekli amel daha değerlidir.", "source": "Öğüt" },
    { "id": 54, "text": "Dua etmek, umudu diri tutar.", "source": "Öğüt" },
    { "id": 55, "text": "Günahı küçümseme, tövbeyi geciktirme.", "source": "Öğüt" },
    { "id": 56, "text": "Kalp temizse dil de temiz olur.", "source": "Öğüt" },
    { "id": 57, "text": "Kötülükten sakınmak ibadettir.", "source": "Öğüt" },
    { "id": 58, "text": "Allah’a güvenen kaybetmez.", "source": "Öğüt" },
    { "id": 59, "text": "Güven, ilişkilerin temelidir.", "source": "Öğüt" },
    { "id": 60, "text": "Sözlerin insanları iyileştirsin, yaralamasın.", "source": "Öğüt" },

    { "id": 61, "text": "İlim öğrenmek, karanlığa ışık yakmaktır.", "source": "Öğüt" },
    { "id": 62, "text": "İbadet sadece namaz değil, güzel davranıştır.", "source": "Öğüt" },
    { "id": 63, "text": "Küçük bir iyilik bile büyüktür.", "source": "Öğüt" },
    { "id": 64, "text": "Gülümsemek sadakadır.", "source": "Öğüt" },
    { "id": 65, "text": "Emanete sahip çıkmak imandandır.", "source": "Öğüt" },
    { "id": 66, "text": "Yalan, kalbi çürütür.", "source": "Öğüt" },
    { "id": 67, "text": "İftira en ağır günahlardandır.", "source": "Öğüt" },
    { "id": 68, "text": "Tövbe kapısı her zaman açıktır.", "source": "Öğüt" },
    { "id": 69, "text": "Allah’ın adaleti şaşmaz.", "source": "Öğüt" },
    { "id": 70, "text": "İnsan, dilinden sorumludur.", "source": "Öğüt" },

    { "id": 71, "text": "Sabrın sonu selamettir.", "source": "Öğüt" },
    { "id": 72, "text": "İyi niyet, kötülüğü bile yumuşatır.", "source": "Öğüt" },
    { "id": 73, "text": "Kin tutma, kalbini temiz tut.", "source": "Öğüt" },
    { "id": 74, "text": "Allah’ın verdiğine razı olmak huzurdur.", "source": "Öğüt" },
    { "id": 75, "text": "İnsanları Allah için sevmek büyük nimettir.", "source": "Öğüt" },
    { "id": 76, "text": "Günahın ardından iyilik yapmak kalbi arındırır.", "source": "Öğüt" },
    { "id": 77, "text": "Zenginlik, paylaşınca anlam kazanır.", "source": "Öğüt" },
    { "id": 78, "text": "İsraf bereketi götürür.", "source": "Öğüt" },
    { "id": 79, "text": "Haram lokma kalbi karartır.", "source": "Öğüt" },
    { "id": 80, "text": "Her gün kendini düzeltmeye çalış.", "source": "Öğüt" },

    { "id": 81, "text": "Kibir, şeytanın yoludur.", "source": "Öğüt" },
    { "id": 82, "text": "Tevazu, müminin süsüdür.", "source": "Öğüt" },
    { "id": 83, "text": "İnsanlara selam vermek sevgi getirir.", "source": "Öğüt" },
    { "id": 84, "text": "Kalbin huzuru Allah’ı anmaktadır.", "source": "Öğüt" },
    { "id": 85, "text": "İyilik eden, kendine iyilik eder.", "source": "Öğüt" },
    { "id": 86, "text": "Zalim olma, mazlumun duasından sakın.", "source": "Öğüt" },
    { "id": 87, "text": "Haksızlık, huzuru yok eder.", "source": "Öğüt" },
    { "id": 88, "text": "Güzel söz, en etkili nasihattir.", "source": "Öğüt" },
    { "id": 89, "text": "Allah, samimiyeti sever.", "source": "Öğüt" },
    { "id": 90, "text": "İnsanlara yük olma, destek ol.", "source": "Öğüt" },

    { "id": 91, "text": "Allah’ın rahmeti umutsuzluğa yer bırakmaz.", "source": "Öğüt" },
    { "id": 92, "text": "Kalbini temiz tut, hayatın güzelleşsin.", "source": "Öğüt" },
    { "id": 93, "text": "Kötü alışkanlıklar ruhu zayıflatır.", "source": "Öğüt" },
    { "id": 94, "text": "İyiliği gizli yapmak daha değerlidir.", "source": "Öğüt" },
    { "id": 95, "text": "İnsanları incitmekten sakın.", "source": "Öğüt" },
    { "id": 96, "text": "Güzel ahlak, en güçlü davettir.", "source": "Öğüt" },
    { "id": 97, "text": "Dünyada misafir olduğunu unutma.", "source": "Öğüt" },
    { "id": 98, "text": "Her gün yeni bir başlangıçtır.", "source": "Öğüt" },
    { "id": 99, "text": "Allah’a yönelen kaybolmaz.", "source": "Öğüt" },
    { "id": 100, "text": "İyilikte yarışmak, hayatı güzelleştirir.", "source": "Öğüt" }
  ]
}